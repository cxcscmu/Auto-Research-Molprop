# Environment variables for the Auto Research agent loop.
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
#
# None of these are needed for the minimal results verification in results/,
# which uses no API key, no training, and no GPU. They are only required to run
# the full closed-loop search (multi_agent_drug.supervisor and the adapters).

# Required for the agent loop: Anthropic API key used by the specialist agents
# to call Claude for hypothesis generation.
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Optional: override where benchmark data is read from (the harness resolves
# sensible defaults if these are unset).
# HARNESS_TDC_DATA_DIR=/path/to/tdc_data
# HARNESS_MOLNET_DATA_DIR=/path/to/molnet_data
# HARNESS_POLARIS_DATA_DIR=/path/to/polaris_data

# Optional: active intervention axis for a run.
# One of: feature_only | model_only | data_only | joint
# HARNESS_ABLATION_MODE=feature_only

# Optional: inner per-trial wall-clock limit in seconds (default 3600).
# HARNESS_WALL_LIMIT_S=3600
